#include <iostream>
#include <thread>
#include <mutex>
#include <condition_variable>

using namespace std;

mutex mtx;
condition_variable cv;

bool isEvenTurn = true; // start with even

void printEven() {
    for (int i = 0; i <= 10; i += 2) {
        unique_lock<mutex> lock(mtx);

        cv.wait(lock, [] { return isEvenTurn; });//makes thread sleep

        cout << "Even: " << i << endl;

        isEvenTurn = false; // switch to odd
        cv.notify_one(); // wakes the other thread
    }
}

void printOdd() {
    for (int i = 1; i < 10; i += 2) {
        unique_lock<mutex> lock(mtx);

        cv.wait(lock, [] { return !isEvenTurn; });

        cout << "Odd:  " << i << endl;

        isEvenTurn = true; // switch to even
        cv.notify_one();
    }
}

int main() {
    thread t1(printEven);
    thread t2(printOdd);

    t1.join();
    t2.join();

    return 0;
}



